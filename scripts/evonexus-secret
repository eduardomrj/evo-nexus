#!/usr/bin/env python3
"""Install allowlisted secrets from Vaultwarden into local runtime files.

This command intentionally has no mode that prints a secret. It only installs
pre-approved Vaultwarden fields into pre-approved destinations.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import stat
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

ALLOWLIST_PATH = Path(os.environ.get("EVONEXUS_SECRET_ALLOWLIST", "/home/evonexus/.config/evonexus/secret-allowlist.yaml"))
BOOTSTRAP_PATH = Path(os.environ.get("EVONEXUS_VAULTWARDEN_BOOTSTRAP", "/home/evonexus/evo-projects-data/evonexus-secrets/vaultwarden-sysops.env"))
AUDIT_LOG = Path(os.environ.get("EVONEXUS_SECRET_AUDIT_LOG", "/home/evonexus/evo-nexus/workspace/infra/audits/evonexus-secret-install.jsonl"))

SENSITIVE_KEYS = {"BW_SESSION", "BW_PASSWORD", "DISCORD_BOT_TOKEN", "OPENCLAUDE_API_KEY"}
DEFAULT_BW_APPDATA_DIR = Path(os.environ.get("EVONEXUS_BW_APPDATA_DIR", "/home/evonexus/evo-projects-data/evonexus-secrets/bitwarden-cli"))


class SafeError(Exception):
    pass


def fail(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def parse_simple_yaml(path: Path) -> dict[str, Any]:
    """Parse the constrained YAML shape used by the allowlist.

    Supports nested maps and inline string lists. This avoids adding runtime
    dependencies and deliberately rejects complex YAML features.
    """
    if not path.exists():
        raise SafeError(f"allowlist not found: {path}")
    lines = path.read_text(encoding="utf-8").splitlines()
    root: dict[str, Any] = {}
    stack: list[tuple[int, dict[str, Any]]] = [(-1, root)]
    for raw in lines:
        if not raw.strip() or raw.lstrip().startswith("#"):
            continue
        indent = len(raw) - len(raw.lstrip(" "))
        text = raw.strip()
        if ":" not in text:
            raise SafeError(f"unsupported allowlist line: {text}")
        key, value = text.split(":", 1)
        key = key.strip().strip('"\'')
        value = value.strip()
        while stack and indent <= stack[-1][0]:
            stack.pop()
        if not stack:
            raise SafeError("invalid indentation in allowlist")
        parent = stack[-1][1]
        if value == "":
            child: dict[str, Any] = {}
            parent[key] = child
            stack.append((indent, child))
        else:
            parent[key] = parse_scalar(value)
    return root


def parse_scalar(value: str) -> Any:
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [part.strip().strip('"\'') for part in inner.split(",")]
    return value.strip('"\'')


def load_env_file(path: Path) -> dict[str, str]:
    env: dict[str, str] = {}
    if not path.exists():
        return env
    st = path.stat()
    if st.st_mode & (stat.S_IRWXG | stat.S_IRWXO):
        raise SafeError(f"bootstrap file permissions too open: {path}")
    for line in path.read_text(encoding="utf-8", errors="ignore").splitlines():
        text = line.strip()
        if not text or text.startswith("#") or "=" not in text:
            continue
        key, value = text.split("=", 1)
        env[key.strip()] = value.strip().strip('"\'')
    return env


def redacted_env(extra: dict[str, str]) -> dict[str, str]:
    DEFAULT_BW_APPDATA_DIR.mkdir(parents=True, exist_ok=True)
    os.chmod(DEFAULT_BW_APPDATA_DIR, 0o700)
    env = os.environ.copy()
    env.setdefault("BITWARDENCLI_APPDATA_DIR", str(DEFAULT_BW_APPDATA_DIR))
    env.update(extra)
    return env


def run_bw(args: list[str], env: dict[str, str]) -> str:
    try:
        proc = subprocess.run(["bw", *args], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, env=env, timeout=30)
    except FileNotFoundError as exc:
        raise SafeError("bw CLI not found") from exc
    except subprocess.TimeoutExpired as exc:
        raise SafeError("bw command timed out") from exc
    if proc.returncode != 0:
        raise SafeError("bw command failed; unlock or refresh the local bootstrap session")
    return proc.stdout


def ensure_bw_session(env: dict[str, str]) -> dict[str, str]:
    status_raw = run_bw(["status"], env)
    try:
        status = json.loads(status_raw)
    except json.JSONDecodeError as exc:
        raise SafeError("bw status returned invalid JSON") from exc
    state = status.get("status")
    if state == "unlocked":
        return env
    if state == "locked" and env.get("BW_SESSION"):
        # Session may still unlock command-specific access; verify by trying status with session already set.
        return env
    if state == "locked" and env.get("BW_PASSWORD"):
        out = run_bw(["unlock", "--raw", env["BW_PASSWORD"]], env)
        session = out.strip()
        if not session:
            raise SafeError("bw unlock returned empty session")
        new_env = dict(env)
        new_env["BW_SESSION"] = session
        return new_env
    raise SafeError("Vaultwarden is locked; provide BW_SESSION in the local bootstrap file")


def get_secret(entry: dict[str, Any], env: dict[str, str]) -> str:
    vault = entry.get("vault", {})
    item_name = vault.get("item_name")
    field = vault.get("field", "password")
    if not item_name or field != "password":
        raise SafeError("only vault field=password is supported")
    # Do not log stdout; this is the secret.
    secret = run_bw(["get", "password", str(item_name)], env).strip()
    if not secret:
        raise SafeError("Vaultwarden returned empty secret")
    return secret


def validate_destination(path: Path, entry: dict[str, Any]) -> None:
    dest = path.resolve(strict=False)
    install = entry.get("install", {})
    allowed = Path(install.get("destination", "")).resolve(strict=False)
    if dest != allowed:
        raise SafeError("destination does not match allowlist")
    for forbidden in entry.get("forbidden_paths", []) or []:
        f = Path(str(forbidden)).resolve(strict=False)
        if dest == f or f in dest.parents or dest in f.parents:
            raise SafeError(f"destination is forbidden by allowlist: {dest}")
    parent = dest.parent
    if parent.exists() and parent.is_symlink():
        raise SafeError("destination parent is a symlink")
    if dest.exists() and dest.is_symlink():
        raise SafeError("destination file is a symlink")


def read_env_lines(path: Path) -> list[str]:
    if not path.exists():
        return []
    if path.is_symlink():
        raise SafeError("destination file is a symlink")
    return path.read_text(encoding="utf-8", errors="ignore").splitlines()


def update_env_content(lines: list[str], key: str, secret: str) -> str:
    pattern = re.compile(rf"^{re.escape(key)}=")
    replacement = f"{key}={secret}"
    updated: list[str] = []
    found = False
    for line in lines:
        if pattern.match(line):
            if not found:
                updated.append(replacement)
                found = True
            continue
        updated.append(line)
    if not found:
        updated.append(replacement)
    return "\n".join(updated).rstrip("\n") + "\n"


def atomic_write(path: Path, content: str, mode: int) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    os.chmod(path.parent, 0o700)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=str(path.parent), text=True)
    tmp = Path(tmp_name)
    try:
        os.fchmod(fd, mode)
        with os.fdopen(fd, "w", encoding="utf-8") as fh:
            fh.write(content)
            fh.flush()
            os.fsync(fh.fileno())
        os.replace(tmp, path)
        os.chmod(path, mode)
    finally:
        if tmp.exists():
            tmp.unlink()


def audit(event: dict[str, Any]) -> None:
    AUDIT_LOG.parent.mkdir(parents=True, exist_ok=True)
    safe = {k: v for k, v in event.items() if k not in SENSITIVE_KEYS}
    safe["ts"] = datetime.now(timezone.utc).isoformat()
    with AUDIT_LOG.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(safe, sort_keys=True) + "\n")


def get_entry(allowlist_id: str) -> dict[str, Any]:
    cfg = parse_simple_yaml(ALLOWLIST_PATH)
    secrets = cfg.get("secrets", {})
    entry = secrets.get(allowlist_id)
    if not isinstance(entry, dict):
        raise SafeError(f"allowlist id not found: {allowlist_id}")
    return entry


def install(allowlist_id: str) -> None:
    entry = get_entry(allowlist_id)
    install_cfg = entry.get("install", {})
    dest = Path(str(install_cfg.get("destination", "")))
    env_key = str(install_cfg.get("env_key", ""))
    mode_text = str(install_cfg.get("file_mode", "0600"))
    if not dest or not env_key:
        raise SafeError("allowlist entry missing destination/env_key")
    mode = int(mode_text, 8)
    if mode != 0o600:
        raise SafeError("only file_mode 0600 is allowed")
    validate_destination(dest, entry)
    bootstrap = load_env_file(BOOTSTRAP_PATH)
    env = ensure_bw_session(redacted_env(bootstrap))
    secret = get_secret(entry, env)
    existing = read_env_lines(dest)
    content = update_env_content(existing, env_key, secret)
    atomic_write(dest, content, mode)
    audit({
        "actor": os.environ.get("USER", "unknown"),
        "action": "install",
        "allowlist_id": allowlist_id,
        "vault_item_name": entry.get("vault", {}).get("item_name"),
        "destination": str(dest),
        "env_key": env_key,
        "result": "success",
        "mode": mode_text,
    })
    print(f"installed {allowlist_id} -> {dest} ({env_key}, mode {mode_text})")


def verify(allowlist_id: str) -> None:
    entry = get_entry(allowlist_id)
    dest = Path(str(entry.get("install", {}).get("destination", "")))
    env_key = str(entry.get("install", {}).get("env_key", ""))
    validate_destination(dest, entry)
    exists = dest.exists()
    mode = oct(dest.stat().st_mode & 0o777) if exists else "missing"
    has_key = False
    if exists:
        for line in read_env_lines(dest):
            if line.startswith(f"{env_key}="):
                has_key = True
                break
    print(json.dumps({"allowlist_id": allowlist_id, "destination": str(dest), "exists": exists, "mode": mode, "has_env_key": has_key}, sort_keys=True))


def list_ids() -> None:
    cfg = parse_simple_yaml(ALLOWLIST_PATH)
    for key in sorted((cfg.get("secrets") or {}).keys()):
        print(key)


def main() -> None:
    parser = argparse.ArgumentParser(description="Install allowlisted secrets without printing them")
    sub = parser.add_subparsers(dest="cmd", required=True)
    p_install = sub.add_parser("install")
    p_install.add_argument("allowlist_id")
    p_verify = sub.add_parser("verify")
    p_verify.add_argument("allowlist_id")
    sub.add_parser("list")
    args = parser.parse_args()
    try:
        if args.cmd == "install":
            install(args.allowlist_id)
        elif args.cmd == "verify":
            verify(args.allowlist_id)
        elif args.cmd == "list":
            list_ids()
    except SafeError as exc:
        fail(str(exc))


if __name__ == "__main__":
    main()
